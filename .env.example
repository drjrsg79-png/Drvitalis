# Anthropic — console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxx

# Base de datos: Netlify Database (Postgres administrado).
# No necesita variables ni llaves: Netlify aprovisiona la base y aplica
# el esquema (netlify/database/migrations) automáticamente en cada deploy.

# Stripe — dashboard.stripe.com → Developers → API Keys
STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxx
STRIPE_PRICE_ID=price_xxxxxxxxxxxxxxxx

# URL pública de tu sitio
NEXT_PUBLIC_URL=https://tu-sitio.netlify.app
